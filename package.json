{
    "name": "revenue-assistant-userscript",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "^22.13.0 || >=24"
    },
    "scripts": {
        "build": "vite build --config ./vite.userscript.config.mjs --mode userscript",
        "build:legacy": "node ./scripts/build.mjs",
        "dev": "node ./scripts/build.mjs --watch",
        "dev:fixture": "vite --config ./vite.fixture.config.mjs",
        "build:vite:fixture": "vite build --config ./vite.fixture.config.mjs",
        "build:vite:candidate": "vite build --config ./vite.userscript.config.mjs --mode candidate",
        "build:compare:vite": "node ./scripts/compare-vite-build.mjs",
        "check:fixture-markers": "node ./scripts/check-rank-fixture-markers.mjs",
        "check:request-scheduler": "node ./scripts/check-request-scheduler.mjs",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "check": "npm run typecheck && npm run lint && npm run build",
        "react:doctor": "react-doctor --yes --no-score --fail-on none",
        "chrome:debug": "pwsh -ExecutionPolicy Bypass -File ./scripts/open-chrome-debug.ps1",
        "chrome:debug:default-profile": "pwsh -ExecutionPolicy Bypass -File ./scripts/open-chrome-debug.ps1 -UseChromeUserData -ProfileDirectory Default",
        "chrome:debug:default-profile:resume": "pwsh -ExecutionPolicy Bypass -File ./scripts/open-chrome-debug.ps1 -UseChromeUserData -ProfileDirectory Default -RestoreLastSession",
        "chrome:profiles": "pwsh -ExecutionPolicy Bypass -File ./scripts/list-chrome-profiles.ps1",
        "chrome:pages": "node ./scripts/attach-chrome.mjs",
        "userscript:version-check": "node ./scripts/check-userscript-version.mjs",
        "smoke:write-posts": "node ./scripts/monitor-write-api-posts.mjs",
        "smoke:distribution": "node ./scripts/run-distribution-smoke.mjs",
        "check:distribution-smoke-fixture": "node ./scripts/run-distribution-smoke.mjs --self-test",
        "check:booking-curve-smoke-fixture": "node ./scripts/check-booking-curve-smoke-fixture.mjs"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/node": "25.8.0",
        "@types/react": "19.2.15",
        "@types/react-dom": "19.2.3",
        "@types/tampermonkey": "5.0.5",
        "@vitejs/plugin-react": "6.0.2",
        "esbuild": "0.28.0",
        "eslint": "10.4.0",
        "globals": "17.6.0",
        "playwright-core": "1.60.0",
        "react-doctor": "0.2.14",
        "typescript": "7.0.2",
        "typescript-eslint": "8.59.3",
        "vite": "8.0.14"
    },
    "dependencies": {
        "@radix-ui/react-popover": "1.1.15",
        "react": "19.2.6",
        "react-dom": "19.2.6"
    }
}
